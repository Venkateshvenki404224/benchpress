[Unit]
Description=BenchPress Shared Infrastructure (MariaDB + Redis)
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/labs/frappe-v16/apps/benchpress/benchpress/config
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose stop
ExecReload=/usr/bin/docker compose up -d --force-recreate
Restart=on-failure

[Install]
WantedBy=multi-user.target
